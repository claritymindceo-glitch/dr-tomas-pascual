# OPENAI_API_KEY: Required for the clinical assistant (OpenAI API).
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# OPENAI_MODEL: Optional. Defaults to gpt-4o-mini.
OPENAI_MODEL="gpt-4o-mini"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ANTHROPIC_API_KEY: Optional. Used to connect to Anthropic Claude 3.5 Sonnet.
# If omitted, the server automatically maps calls dynamically to Gemini as a high-fidelity fallback.
ANTHROPIC_API_KEY=""

# Formulario Consultar → email vía Gmail SMTP (Google)
# Requiere contraseña de aplicación: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="claritymind.ceo@gmail.com"
SMTP_PASS=""
CONTACT_EMAIL_TO="claritymind.ceo@gmail.com"
CONTACT_EMAIL_FROM="Consultas Dr. Pascual <claritymind.ceo@gmail.com>"
