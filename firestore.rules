rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Consultas del formulario web: solo backend (Admin SDK). Clientes sin acceso.
    match /consultas/{consultaId} {
      allow read, write: if false;
    }

    match /{collection}/{document=**} {
      allow read, write: if collection != "consultas"
        && request.time < timestamp.date(2026, 6, 26);
    }
  }
}
